{
  "name": "@firsttimers/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts | bunx pino-pretty",
    "build": "bun build src/index.ts --target bun --outdir dist --external @prisma/client --external @prisma/client-runtime-utils --external @sentry/bun --external @opentelemetry/api",
    "start": "bun run dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/bun": "^10.50.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.2",
    "hono": "^4.12.15",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firsttimers/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.13",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.0.0",
    "typescript": "^6.0.3"
  }
}
